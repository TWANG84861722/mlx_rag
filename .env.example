# ─────────────────────────────────────────────────────────────
#  .env.example —— 环境变量模板
#  用法：  cp .env.example .env   然后编辑 .env 填入你的真 key
#  说明：  .env 被 .gitignore 忽略（不进库、不泄露）；这份模板会进库，
#          让别人（和以后的你）一看就知道需要配哪些 key。
# ─────────────────────────────────────────────────────────────

# 默认用 qwen（见 models.yaml 的 active）→ 必填这个（国际版 DashScope 端点）
DASHSCOPE_API_KEY=your-dashscope-intl-key-here

# 仅当切到其它 provider 时才需要（在 models.yaml 改 active / *_override）
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── 可选：跨平台 / 本地模型覆盖 ──────────────────────────────
# 都不设时自动：Apple Silicon → 本机 ~/models + MLX；其它平台 → 从 HuggingFace 自动下载。
# EMBED_BACKEND=auto            # auto | mlx | st(sentence-transformers, 跨平台/GPU)
# EMBED_MODEL=BAAI/bge-m3
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
